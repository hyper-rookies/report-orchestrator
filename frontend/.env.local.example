NEXT_PUBLIC_COGNITO_USER_POOL_ID=ap-northeast-2_XXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=XXXXX
NEXT_PUBLIC_COGNITO_DOMAIN=YOUR_COGNITO_DOMAIN.auth.ap-northeast-2.amazoncognito.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
ORCHESTRATOR_URL=https://YOUR_LAMBDA_FUNCTION_URL.lambda-url.ap-northeast-2.on.aws/
NEXT_PUBLIC_REPORT_API_URL=https://YOUR_REPORT_LAMBDA_URL.lambda-url.ap-northeast-2.on.aws/
NEXT_PUBLIC_USE_MOCK_AUTH=false
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
# Optional when using temporary credentials in Vercel / CI
AWS_SESSION_TOKEN=
SESSION_BUCKET=your-session-and-share-bucket
SHARE_TOKEN_SECRET=replace-with-a-32-char-random-secret
